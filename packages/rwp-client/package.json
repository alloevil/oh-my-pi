{
	"type": "module",
	"name": "@oh-my-pi/rwp-client",
	"version": "14.9.3",
	"description": "TypeScript client for the Remote Workspace Protocol server",
	"homepage": "https://github.com/can1357/oh-my-pi",
	"author": "Can Boluk",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/can1357/oh-my-pi.git",
		"directory": "packages/rwp-client"
	},
	"bugs": {
		"url": "https://github.com/can1357/oh-my-pi/issues"
	},
	"keywords": [
		"rwp",
		"remote-workspace-protocol",
		"client",
		"typescript"
	],
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"scripts": {
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"generate": "bun run scripts/generate.ts",
		"lint": "biome lint .",
		"test": "bun test",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write ."
	},
	"dependencies": {
		"@oh-my-pi/pi-coding-agent": "workspace:^"
	},
	"devDependencies": {
		"@types/bun": "catalog:",
		"openapi-typescript": "^7.10.1"
	},
	"engines": {
		"bun": ">=1.3.7"
	},
	"files": [
		"src",
		"README.md"
	],
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./*": {
			"types": "./src/*.ts",
			"import": "./src/*.ts"
		},
		"./*.js": "./src/*.ts"
	}
}
